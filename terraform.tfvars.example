# ============================================================
#  terraform.tfvars  (example – do NOT commit passwords to git)
#  In production, source passwords from AWS Secrets Manager
#  and pass them via a data source or CI/CD secret injection.
# ============================================================

environment = "dev"
region      = "us-east-1"

# ── Aurora connectivity ──────────────────────────────────────
aurora_host               = "cariai-cluster.cluster-xxxxxxxxxx.us-east-1.rds.amazonaws.com"
aurora_port               = 3306
aurora_vpc_id             = "vpc-0abc123def456789a"
aurora_subnet_ids         = ["subnet-0111aaa", "subnet-0222bbb"]
aurora_security_group_ids = ["sg-0cariai123456"]

# ── S3 buckets ───────────────────────────────────────────────
landing_bucket_name   = "dev-landing"
logs_bucket_name      = "dev-logs"
resources_bucket_name = "dev-resources"
cariai_prefix         = "cariai"

# ── Glue job ─────────────────────────────────────────────────
glue_version        = "4.0"
python_version      = "3"
number_of_workers   = 4
worker_type         = "G.1X"
job_timeout_minutes = 120
max_retries         = 0

# ── Schedule: 05:00 COT every day (UTC-5, no DST in Colombia) ─
schedule_cron    = "cron(0 10 * * ? *)"
schedule_enabled = true

# ── 36 CarIAI WhatsApp schemas ───────────────────────────────
# Replace with real credentials; use Secrets Manager in production.
cariai_schemas = [
  { schema_name = "cariai_wa_001", username = "user_001", password = "CHANGE_ME" },
  { schema_name = "cariai_wa_002", username = "user_002", password = "CHANGE_ME" },
